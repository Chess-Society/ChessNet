# Firebase Admin Credentials
# Descarga el JSON de tu cuenta de servicio desde Firebase Console -> Configuración -> Cuentas de servicio
FB_PROJECT_ID=tu-proyecto-id
FB_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto-id.iam.gserviceaccount.com
FB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Public Config
PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto-id

# Local Dev
DEV_AUTH_BYPASS_SECRET=antigravity-dev-secret
