# Supabase Configuration
# IMPORTANTE: Reemplaza estos valores con tus credenciales reales de Supabase
# Puedes encontrar estos valores en tu dashboard de Supabase: https://supabase.com/dashboard
PUBLIC_SUPABASE_URL=https://tu-proyecto-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Site Configuration
PUBLIC_SITE_URL=https://chessnet.app

# Google OAuth (configurado en Supabase Dashboard)
# No se necesitan variables de entorno adicionales para Google OAuth

# INSTRUCCIONES:
# 1. Copia este archivo como .env en la raíz del proyecto
# 2. Reemplaza los valores de ejemplo con tus credenciales reales
# 3. Para producción en Netlify, configura estas variables en:
#    Netlify Dashboard > Site Settings > Environment Variables
