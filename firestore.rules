rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() { return request.auth != null; }
    
    // SuperAdmin: Acceso total basado en Custom Claim 'admin' o lista de correos autorizados
    function isSuperAdmin() { 
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        request.auth.token.email.lower() in [
          "andreslgumuzio@gmail.com", 
          "tomih@chess-society.com",
          "escuelatopchess@gmail.com",
          "tomihersan@gmail.com"
        ]
      );
    }
    
    function isOwner(docData) { return docData.owner_id == request.auth.uid; }
    function isShared(docData) { 
      return isAuthenticated() && 
        ('sharedWith' in docData && request.auth.uid in docData.sharedWith);
    }
    
    // Perfiles y Configuración de usuario (Identificados por UID)
    match /users/{userId} {
      allow read, write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
      
      // Permitir acceso a subcolecciones de usuario (settings, appData, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
      }
    }
    
    match /app_settings/{userId} {
      allow read, write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    match /user_subscriptions/{userId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isSuperAdmin();
    }
    
    // Configuración del sistema y Logs (Solo Admin)
    // Configuración del sistema y Logs
    match /system/config {
      // Público para modo mantenimiento
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    match /system/{docId} {
      allow read, write: if isSuperAdmin();
    }
    
    match /system_logs/{docId} {
      allow read, write: if isSuperAdmin();
    }
    
    match /announcements/{docId} {
      allow read: if true; // Global announcements public
      allow write: if isSuperAdmin();
    }
    
    // Lobby: Sugerencias de la comunidad
    match /lobby_suggestions/{suggestionId} {
      allow read: if isAuthenticated();
      allow delete: if isSuperAdmin();
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']))
      );
    }

    // Lobby: Comunicados oficiales
    match /lobby_announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Lobby: Reportes de soporte (Privados: Autor + Admin)
    // SEGURIDAD: Separar create/update/delete para evitar modificación de campos sensibles
    match /lobby_reports/{reportId} {
      // Lectura: solo el autor del reporte o un admin
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
      // Crear: solo el propio usuario, debe ser el autor
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      // Actualizar: el usuario puede añadir mensajes pero NO puede cambiar authorId, status ni createdAt
      allow update: if isSuperAdmin() || (
        isAuthenticated() &&
        resource.data.authorId == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['authorId', 'status', 'createdAt'])
      );
      // Eliminar: solo el admin puede borrar tickets
      allow delete: if isSuperAdmin();
    }

    // Lobby: Grupos de la comunidad
    match /community_groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // Lobby: Mensajería de la comunidad
    match /community_messages/{messageId} {
      allow read: if isAuthenticated();
      // SEC-04: Validar estructura y limitar tamaño para prevenir flood/mensajes malformados
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.keys().hasAll(['authorId', 'content', 'createdAt'])
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 2000;
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    // --- CORE BUSINESS ASSETS (Restricted to Server/Admin) ---
    // We deny client-side creation to enforce Freemium limits and security via API
    
    match /schools/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && (isOwner(resource.data) || isShared(resource.data)));
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && isOwner(resource.data));
      allow create: if isSuperAdmin() || (isAuthenticated() && request.resource.data.owner_id == request.auth.uid);
    }
    
    match /classes/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && (isOwner(resource.data) || isShared(resource.data)));
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && isOwner(resource.data));
      allow create: if isSuperAdmin() || (isAuthenticated() && request.resource.data.owner_id == request.auth.uid);
    }
    
    match /students/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && (isOwner(resource.data) || isShared(resource.data)));
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && isOwner(resource.data));
      allow create: if isSuperAdmin() || (isAuthenticated() && request.resource.data.owner_id == request.auth.uid);
    }

    match /payments/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create, update: if isSuperAdmin(); // Only server/admin can create/update payments
      allow delete: if isSuperAdmin(); // Restrict deletion to SuperAdmin for audit integrity
    }

    match /achievements/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin(); // Only server can grant achievements
    }

    // --- SECONDARY ASSETS & PROGRESS TRACKING ---
    
    match /curriculum_units/{docId} {
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /lessons/{docId} {
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /lesson_resources/{docId} {
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /local_tournaments/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && (isOwner(resource.data) || isShared(resource.data)));
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && isOwner(resource.data));
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /local_tournament_players/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && (isOwner(resource.data) || isShared(resource.data)));
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && isOwner(resource.data));
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /local_tournament_pairings/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && (isOwner(resource.data) || isShared(resource.data)));
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && isOwner(resource.data));
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /local_tournament_rounds/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && (isOwner(resource.data) || isShared(resource.data)));
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && isOwner(resource.data));
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /tournament_participants/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow write: if isSuperAdmin();
    }

    match /tournament_matches/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow write: if isSuperAdmin();
    }

    match /badges/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource.data.owner_id == request.auth.uid);
      allow write: if isSuperAdmin();
    }

    match /student_badges/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource.data.owner_id == request.auth.uid);
      allow write: if isSuperAdmin();
    }

    match /student_stats/{studentId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || resource.data.owner_id == request.auth.uid);
      allow write: if isSuperAdmin();
    }

    match /activity_logs/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow write: if isSuperAdmin();
    }

    match /class_students/{docId} {
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /class_skills/{docId} {
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /attendance/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      // El propietario puede crear y actualizar su propio registro de asistencia
      // (las operaciones en lote pasan por el API con Admin SDK, las individuales desde el cliente)
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
      allow update: if isSuperAdmin() || (
        isAuthenticated() &&
        resource.data.owner_id == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['owner_id'])
      );
      allow delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
    }

    match /skills/{docId} {
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /chess_exercises/{docId} {
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /exercise_attempts/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
      allow update, delete: if isSuperAdmin();
    }

    match /parent_messages/{docId} {
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    match /leads/{docId} {
      allow read, update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.owner_id == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.owner_id == request.auth.uid;
    }

    // --- SOCIAL & GOVERNANCE (SISTEMA DE HITOS) ---

    match /faculty_stream/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin() || (isAuthenticated() && resource.data.authorId == request.auth.uid);
    }

    match /prediction_markets/{docId} {
      allow read: if isAuthenticated();
      // Permitir creación a SuperAdmins o Directores de la escuela correspondiente
      allow create: if isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)) &&
        get(/databases/$(database)/documents/schools/$(request.resource.data.schoolId)).data.owner_id == request.auth.uid
      );
      // Permitir actualización: 
      // 1. SuperAdmins pueden todo
      // 2. Directores pueden editar detalles o resolver hitos de su escuela
      // 3. Usuarios pueden participar (pools) o disputar
      allow update: if isSuperAdmin() || (
        isAuthenticated() && (
          (
            // Edición de detalles por Director
            resource.data.status == 'OPEN' &&
            get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data.owner_id == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['question', 'description', 'endDate', 'updatedAt', 'tags', 'validationSource', 'externalId'])
          ) || (
            // Resolución por Director
            get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data.owner_id == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'resultOptionId', 'resolvedAt', 'resolutionProposedAt'])
          ) || (
            // Participación de usuario (Actualización de pools) o Disputa
            request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalPool', 'options', 'updatedAt', 'status', 'disputedBy'])
          )
        )
      );
      allow delete: if isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/schools/$(resource.data.schoolId)) &&
        get(/databases/$(database)/documents/schools/$(resource.data.schoolId)).data.owner_id == request.auth.uid
      );
    }

    match /prediction_bets/{docId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Solo el propio usuario puede crear su pronóstico
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Permitir actualización para añadir más Nets al mismo pronóstico
      // SEGURIDAD: No se pueden cambiar campos de identidad ni el mercado
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['userId', 'marketId', 'schoolId', 'amount', 'createdAt']);
    }

    // Default deny for anything else
    match /{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
