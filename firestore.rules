rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() { return request.auth != null; }
    
    // Lista de administradores autorizados
    function isSuperAdmin() { 
      return isAuthenticated() && 
        request.auth.token.email in ["andreslgumuzio@gmail.com", "tomih@chess-society.com", "admin@chessnet.app", "admin@chessnet.pro"];
    }
    
    function isOwner(docData) { return docData.owner_id == request.auth.uid; }
    
    // Perfiles y Configuración de usuario (Identificados por UID)
    match /users/{userId} {
      allow read, write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }
    
    match /app_settings/{userId} {
      allow read, write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    match /user_subscriptions/{userId} {
      allow read, write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }
    
    // Configuración del sistema y Logs (Solo Admin)
    match /system/{docId} {
      allow read, write: if isSuperAdmin();
    }
    
    match /system_logs/{docId} {
      allow read, write: if isSuperAdmin();
    }
    
    match /announcements/{docId} {
      allow read, write: if isSuperAdmin();
    }
    
    // Regla maestra para datos de negocio (centros, clases, alumnos)
    match /{collection}/{docId} {
      allow read, create, update, delete: if isSuperAdmin() || 
        (isAuthenticated() && (
          (resource != null && isOwner(resource.data)) || 
          (request.resource != null && isOwner(request.resource.data))
        ));
    }
  }
}
