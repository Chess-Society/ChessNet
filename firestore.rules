rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() { return request.auth != null; }
    function isOwner(docData) { return docData.owner_id == request.auth.uid; }
    
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /{collection}/{docId} {
      allow read, create, update, delete: if isAuthenticated() && (isOwner(resource.data) || isOwner(request.resource.data));
    }
  }
}
