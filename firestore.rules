rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() { return request.auth != null; }
    function isSuperAdmin() { 
      return isAuthenticated() && request.auth.token.email == "andreslgumuzio@gmail.com";
    }
    function isOwner(docData) { return docData.owner_id == request.auth.uid; }
    
    // El perfil del usuario es privado por defecto
    match /users/{userId} {
      allow read, write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }
    
    // Regla maestra para colecciones de datos (alumnos, centros, etc.)
    match /{collection}/{docId} {
      // Permitimos lectura y escritura si es el Super Admin o el dueño del dato
      allow read, create, update, delete: if isSuperAdmin() || (isAuthenticated() && (isOwner(resource.data) || isOwner(request.resource.data)));
    }
  }
}
