rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the user is the super-admin
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == "andreslgumuzio@gmail.com";
    }

    // Admin can read all users and their configuration
    match /users/{userId} {
      allow read: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Admin can monitor all nested data (appData, config, etc.)
      match /{allPaths=**} {
        allow read: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
        allow write: if isSuperAdmin() || (request.auth != null && request.auth.uid == userId);
      }
    }
    
    // Explicitly deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
